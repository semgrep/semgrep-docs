#!/usr/bin/env bash
# Build docs/snippets/metrics.mdx from Semgrep's upstream metrics.md.
# Imported by docs/metrics.mdx and docs/metrics-1.mdx via:
#   import Metrics from "/snippets/metrics.mdx"
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
OUTPUT="${REPO_ROOT}/docs/snippets/metrics.mdx"
METRICS_URL="https://raw.githubusercontent.com/semgrep/semgrep/develop/metrics.md"

cat > "$OUTPUT" <<'HEADER'
- [the principles that guide our data-collection decisions](#principles)
- [how to change when Semgrep sends metrics](#automatic-collection-opt-in-and-opt-out)
- [what data is not collected](#data-not-collected)
- [what data is collected](#data-collected-as-metrics)


HEADER

curl -fsSL "$METRICS_URL" >> "$OUTPUT"
echo "Wrote $OUTPUT"
